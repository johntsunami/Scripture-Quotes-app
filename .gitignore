# Dependencies
node_modules/

# Build output
dist/
out/
release/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
*.swp

# Editor
.vscode/
.idea/
*.iml

# Local user data — personal quotes, favorites, settings, rotation state.
# These live only on the user's machine and never get committed.
# Built-in decks live in assets/decks/ and ARE committed.
data/

# Environment / secrets — should never end up in a public repo
.env
.env.local
*.pem
*.key

# Misc
*.tmp
*.migrated
